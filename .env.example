# Copiez ce fichier vers .env pour Docker Compose ou .env.local pour npm.
# Utilisez un mot de passe long et unique.
ADMIN_PASSWORD=

# Au moins 32 caractères aléatoires. Exemple de génération :
# node -e "console.log(require('node:crypto').randomBytes(48).toString('base64url'))"
ADMIN_SESSION_SECRET=

# Docker Compose remplace cette valeur par /app/data.
APP_DATA_DIR=.data
APP_PORT=3100
NEXT_PUBLIC_SITE_URL=http://localhost:3100

# Laissez vide pour le déduire de NEXT_PUBLIC_SITE_URL. Forcez true derrière HTTPS.
ADMIN_COOKIE_SECURE=
